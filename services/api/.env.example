APP_NAME=coachella-api
APP_ENV=local
APP_VERSION=0.1.0
API_PREFIX=/v1

# Leave DATABASE_URL empty to use SQLite locally.
# Set to a Postgres connection string for production (Neon free tier).
SQLITE_PATH=./coachella.db
DATABASE_URL=

# Anthropic API key (from console.anthropic.com → API Keys).
# Required for schedule image parsing in production.
# Leave empty for local dev — the app falls back to demo OCR data when unset.
ANTHROPIC_API_KEY=
