{
  "expo": {
    "name": "Festival Together",
    "slug": "festival-together",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "festivaltogether",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f3a8d0"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.festivaltogether.app",
      "buildNumber": "1.0.24",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Festival Together needs access to your photo library so you can upload screenshots of the festival schedule.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.festivaltogether.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#fff4e6"
      },
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "extra": {
      "appEnv": "production",
      "eas": {
        "projectId": "bb2b2270-8beb-4240-bb21-f62e32e2606d"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
